pipeline {
    agent any

    environment {
        TERRAFORM_IMAGE = "hashicorp/terraform:1.14.7"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            steps {
                sh """docker run --rm -v \$PWD:/workspace -w /workspace ${TERRAFORM_IMAGE} init"""
            }
        }

        stage('Terraform Plan') {
            steps {
                sh """docker run --rm -v \$PWD:/workspace -w /workspace ${TERRAFORM_IMAGE} plan -out=tfplan"""
            }
        }

        stage('Approval') {
            steps {
                input message: 'Apply Terraform changes?', ok: 'Apply'
            }
        }

        stage('Terraform Apply') {
            steps {
                sh """docker run --rm -v \$PWD:/workspace -w /workspace ${TERRAFORM_IMAGE} apply -auto-approve tfplan"""
            }
        }

        // Multibranch uses detached HEAD; push with BRANCH_NAME not git rev-parse.
        stage('Commit and push apply') {
            steps {
                sh """
                    git config user.email "jenkins@localhost"
                    git config user.name "Jenkins CI"
                    git add -A
                    if git diff --staged --quiet; then
                      echo "No changes to commit after apply."
                    else
                      MSG=\$(date -u +%Y-%m-%dT%H:%M:%SZ)
                      git commit -m "Terraform Apply [\$MSG]"
                      git push origin HEAD:${env.BRANCH_NAME ?: 'main'}
                    fi
                """
            }
        }
    }

    post {
        always {
            echo 'Cleaning up workspace...'
            sh """ls -la ${WORKSPACE}"""
            cleanWs()
            echo 'after cleanWs'
            sh """ls -la ${WORKSPACE}"""
        }
    }
}

